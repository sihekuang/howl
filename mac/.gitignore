# DerivedData (Xcode build outputs)
DerivedData/
build/

# Local Xcode user state
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# Note: the .xcodeproj IS tracked. We commit the regenerated project
# alongside project.yml so a fresh clone can open in Xcode without
# running xcodegen first. The post-merge git hook keeps the tracked
# .pbxproj in sync with project.yml after pulls (see scripts/git-hooks/).
# We still ignore xcuserdata above so per-developer Xcode state
# (window positions, breakpoints, etc.) doesn't leak into git.

# Per-machine signing config — see Local.xcconfig.sample
Local.xcconfig
