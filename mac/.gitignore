# DerivedData (Xcode build outputs)
DerivedData/
build/

# Local Xcode user state
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.swiftpm/
.build/
Package.resolved

# Note: the .xcodeproj IS tracked (we commit the regenerated project
# alongside project.yml so a fresh clone can open it in Xcode without
# running xcodegen). xcodegen is deterministic for our config — the
# Configs/ subdirectory placement of SharedSettings.xcconfig avoids
# the TEMP_id drift that would otherwise produce different .pbxproj
# SHAs on every regen. xcuserdata is still ignored above so per-dev
# Xcode UI state doesn't leak.

# Per-machine signing config — see Configs/DeveloperSettings.xcconfig.sample.
# Optional override pulled in by Configs/SharedSettings.xcconfig if present.
Configs/DeveloperSettings.xcconfig

# Legacy name (pre-restructure). Ignored so old clones don't accidentally
# commit it after pulling the rename.
Local.xcconfig
