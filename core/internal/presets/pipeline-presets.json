{
  "version": 1,
  "presets": [
    {
      "name": "default",
      "description": "Standard pipeline: denoise → TSE (soft gate) → decimate → Whisper → dict → LLM cleanup.",
      "frame_stages": [
        {"name": "denoise",   "enabled": true},
        {"name": "decimate3", "enabled": true}
      ],
      "chunk_stages": [
        {"name": "tse", "enabled": true, "backend": "ecapa", "threshold": 0.25}
      ],
      "transcribe": {"model_size": "small"},
      "llm":        {"provider": "anthropic", "model": "claude-sonnet-4-6"},
      "timeout_sec": 10
    },
    {
      "name": "minimal",
      "description": "No denoise, no TSE — fastest, lowest latency. Works well for quiet environments.",
      "frame_stages": [
        {"name": "denoise",   "enabled": false},
        {"name": "decimate3", "enabled": true}
      ],
      "chunk_stages": [
        {"name": "tse", "enabled": false, "backend": "ecapa", "threshold": 0.0}
      ],
      "transcribe": {"model_size": "small"},
      "llm":        {"provider": "anthropic", "model": "claude-sonnet-4-6"},
      "timeout_sec": 5
    },
    {
      "name": "aggressive",
      "description": "Denoise + TSE with moderate gate + larger Whisper. ⚠️ May cut audio in quiet environments — best when another speaker is nearby.",
      "frame_stages": [
        {"name": "denoise",   "enabled": true},
        {"name": "decimate3", "enabled": true}
      ],
      "chunk_stages": [
        {"name": "tse", "enabled": true, "backend": "ecapa", "threshold": 0.35}
      ],
      "transcribe": {"model_size": "base"},
      "llm":        {"provider": "anthropic", "model": "claude-sonnet-4-6"},
      "timeout_sec": 15
    },
    {
      "name": "paranoid",
      "description": "Denoise + TSE with strict gate — silences low-confidence chunks. ⚠️ Will cut audio unless someone is literally talking next to you.",
      "frame_stages": [
        {"name": "denoise",   "enabled": true},
        {"name": "decimate3", "enabled": true}
      ],
      "chunk_stages": [
        {"name": "tse", "enabled": true, "backend": "ecapa", "threshold": 0.45}
      ],
      "transcribe": {"model_size": "small"},
      "llm":        {"provider": "anthropic", "model": "claude-sonnet-4-6"},
      "timeout_sec": 10
    }
  ]
}
