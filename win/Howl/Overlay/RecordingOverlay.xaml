<Window x:Class="Howl.Overlay.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Width="240" Height="44"
        WindowStartupLocation="Manual">

    <Border CornerRadius="22" Background="#C8000000">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Margin="14,0">

            <!-- Recording: pulsing red dot -->
            <Ellipse x:Name="RecordDot" Width="8" Height="8" Fill="#FF4444"
                     VerticalAlignment="Center">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.25"
                                                 Duration="0:0:0.7" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Processing: spinning arc -->
            <Path x:Name="Spinner" Data="M 8,0 A 8,8 0 1 1 0,8" Stroke="White"
                  StrokeThickness="2" Width="16" Height="16"
                  VerticalAlignment="Center" Visibility="Collapsed">
                <Path.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" CenterX="8" CenterY="8"/>
                </Path.RenderTransform>
            </Path>

            <TextBlock x:Name="StatusText" Text="Recording"
                       Foreground="White" FontSize="13" FontWeight="Medium"
                       VerticalAlignment="Center" Margin="8,0"/>

            <!-- RMS level bar (visible during recording) -->
            <Border x:Name="LevelBar" Width="0" Height="4"
                    Background="#80FFFFFF" CornerRadius="2"
                    VerticalAlignment="Center" Visibility="Collapsed"/>

        </StackPanel>
    </Border>
</Window>
