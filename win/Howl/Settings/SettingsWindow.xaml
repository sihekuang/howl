<Window x:Class="Howl.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Howl Settings"
        Width="520" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Width" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="12,12,12,0">

            <!-- ══ General Tab ══ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8,16,16">

                        <TextBlock Text="Transcription" Style="{StaticResource SectionHeader}"/>
                        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Model size" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="ModelSizeBox" HorizontalAlignment="Left" Width="280"
                                      SelectionChanged="ModelSize_Changed"/>
                        </DockPanel>
                        <TextBlock x:Name="ModelSizeHint" Style="{StaticResource Caption}" Margin="120,0,0,8"/>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Model file" Style="{StaticResource Label}"/>
                            <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0"
                                    Click="BrowseModel_Click" Padding="8,3" FontSize="12"/>
                            <Button DockPanel.Dock="Right" Content="Download" Margin="8,0,0,0"
                                    Click="DownloadModel_Click" Padding="8,3" FontSize="12"/>
                            <TextBox x:Name="ModelPathBox"/>
                        </DockPanel>
                        <TextBlock x:Name="ModelStatusText" Style="{StaticResource Caption}"/>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Language" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="LanguageBox" HorizontalAlignment="Left" Width="200"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Microphone" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="MicBox" HorizontalAlignment="Left" Width="300"/>
                        </DockPanel>

                        <TextBlock Text="Pipeline" Style="{StaticResource SectionHeader}"/>
                        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Timeout (sec)" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TimeoutBox" Width="60" HorizontalAlignment="Left"/>
                        </DockPanel>
                        <TextBlock Text="Max seconds the pipeline runs after you release the hotkey. 0 = no limit."
                                   Style="{StaticResource Caption}" Margin="120,0,0,8"/>

                        <TextBlock Text="General" Style="{StaticResource SectionHeader}"/>
                        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>
                        <CheckBox x:Name="LaunchAtLoginBox" Content="Launch at login" FontSize="12"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ LLM Tab ══ -->
            <TabItem Header="AI / LLM">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8,16,16">

                        <TextBlock Text="AI Post-processing" Style="{StaticResource SectionHeader}"/>
                        <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>
                        <TextBlock Text="An LLM cleans up punctuation, capitalisation and filler words. Leave the API key blank to use raw Whisper output."
                                   Style="{StaticResource Caption}"/>

                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Provider" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="ProviderBox" HorizontalAlignment="Left" Width="220"
                                      SelectionChanged="Provider_Changed"/>
                        </DockPanel>

                        <DockPanel x:Name="ApiKeyRow" Margin="0,0,0,4">
                            <TextBlock Text="API key" Style="{StaticResource Label}"/>
                            <PasswordBox x:Name="ApiKeyBox"/>
                        </DockPanel>
                        <TextBlock x:Name="ApiKeyHint" Style="{StaticResource Caption}" Margin="120,0,0,8"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ Dictionary Tab ══ -->
            <TabItem Header="Dictionary">
                <StackPanel Margin="16,8,16,16">

                    <TextBlock Text="Custom Dictionary" Style="{StaticResource SectionHeader}"/>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>
                    <TextBlock Text="One word or phrase per line. Helps Whisper spell domain-specific terms correctly."
                               Style="{StaticResource Caption}"/>
                    <TextBox x:Name="DictBox" AcceptsReturn="True" Height="280"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                             VerticalContentAlignment="Top" Padding="6"/>

                </StackPanel>
            </TabItem>

            <!-- ══ Presets Tab ══ -->
            <TabItem Header="Presets">
                <StackPanel Margin="16,8,16,16">

                    <TextBlock Text="Active Preset" Style="{StaticResource SectionHeader}"/>
                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,10"/>
                    <TextBlock Text="Presets bundle Whisper + LLM settings into named profiles. The active preset is applied when you dictate."
                               Style="{StaticResource Caption}"/>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Active preset" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="PresetBox" HorizontalAlignment="Left" Width="220"/>
                    </DockPanel>

                    <TextBlock x:Name="PresetDescText" TextWrapping="Wrap" FontSize="11"
                               Foreground="#666" Margin="0,0,0,0"/>

                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ── Bottom buttons ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="12,8,12,12">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="Cancel_Click" Padding="0,6"/>
            <Button Content="Save"   Width="80" IsDefault="True"  Click="Save_Click"   Padding="0,6"/>
        </StackPanel>
    </Grid>
</Window>
