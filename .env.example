# Copy this file to .env and fill in the values you need.
# .env is gitignored — never commit real keys.

# Required if using Anthropic for LLM cleanup (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# Required if using OpenAI for LLM cleanup
OPENAI_API_KEY=sk-...

# Path to a Whisper model file (.bin). Used by run.sh / vkb-cli.
# Download models from: https://huggingface.co/ggerganov/whisper.cpp
VKB_MODEL_PATH=/path/to/whisper-small.bin

# Optional: path to libonnxruntime.dylib if not in the Homebrew default location.
# Default: /opt/homebrew/lib/libonnxruntime.dylib
# ONNXRUNTIME_LIB_PATH=/opt/homebrew/lib/libonnxruntime.dylib
